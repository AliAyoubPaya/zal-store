    "custom_liquid_cFpNXY": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<div class=\"custom-section\">\n\n  <div class=\"content\">\n    <h2> What<span>Zaal Mart </span> Is All About </h2>\n    <p>We started Zaal Mart with a simple vision: to make online shopping easier, more convenient, and more affordable for everyone. Our goal is to bring a wide variety of products together in one place, so you can find your favorite items and everyday essentials without the hassle of browsing multiple stores.</p>\n    <p>From home décor and kitchen essentials to baby care products and the latest trending items, Zaal Mart offers a diverse selection for every home and lifestyle. Our mission is to make quality products accessible while providing a smooth and reliable shopping experience.</p>\n<p>We are dedicated to offering competitive prices, exciting deals, and products that add value to your everyday life. Whether you are shopping for necessities or treating yourself to something special, you can count on Zaal Mart to deliver great choices at affordable prices.</p>\n    <a href=\"/pages/about-us-2\">Start Shopping</a>\n  </div>\n\n  <div class=\"video-box\">\n    <video class=\"custom-video\" poster=\"https://cdn.shopify.com/s/files/1/0896/2467/4598/files/ProSwag_About-Us-Short_poster.webp\">\n      <source src=\"https://cdn.shopify.com/videos/c/o/v/57ad3c66d6bc4b82af1d9d768dde8137.webm\" type=\"video/mp4\">\n    </video>\n    <button class=\"play-btn\"></button>\n  </div>\n\n</div>",
        "color_scheme": "background-1",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
