x;\n  box-shadow:0 2px 10px rgba(0,0,0,.05);\n  flex-shrink:0;\n}\n\n.usp-icon{\n  font-size:34px;\n  line-height:1;\n}\n\n.usp-content h4{\n  margin:0;\n  font-size:18px;\n  font-weight:600;\n  line-height:1.3;\n}\n\n.usp-content p{\n  margin:4px 0 0;\n  font-size:14px;\n  color:#666;\n  line-height:1.4;\n}\n\n@keyframes usp-scroll{\n  0%{\n    transform:translateX(0);\n  }\n  100%{\n    transform:translateX(-50%);\n  }\n}\n\n/* Tablet */\n\n@media screen and (max-width: 990px){\n\n  .usp-box{\n    min-width:300px;\n    padding:14px 18px;\n  }\n\n  .usp-icon{\n    font-size:30px;\n  }\n\n  .usp-content h4{\n    font-size:16px;\n  }\n\n  .usp-content p{\n    font-size:13px;\n  }\n\n}\n\n/* Mobile */\n\n@media screen and (max-width: 749px){\n\n  .usp-marquee-wrapper{\n    padding:10px 0;\n  }\n\n  .usp-marquee-track{\n    gap:15px;\n    animation-duration:18s;\n  }\n\n  .usp-box{\n    min-width:260px;\n    padding:12px 16px;\n    border-radius:10px;\n  }\n\n  .usp-icon{\n    font-size:26px;\n  }\n\n  .usp-content h4{\n    font-size:14px;\n  }\n\n  .usp-content p{\n    font-size:12px;\n  }\n\n}\n\n</style>",
