    "collapsible_content_m7xNMA": {
      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_LpQ4VB": {
          "type": "collapsible_row",
          "settings": {
            "heading": "1. How do I place an order?",
            "icon": "none",
            "row_content": "<p>When you find something, you like, simply add it to your cart and proceed to<br/>checkout. Fill in your delivery details, place your order, and we'll handle the<br/>rest while you look forward to receiving your purchase.</p>",
            "page": ""
          }
        },
        "collapsible_row_fU8w77": {
          "type": "collapsible_row",
          "settings": {
            "heading": "2. Do you offer Cash on Delivery?",
            "icon": "none",
            "row_content": "<p>Absolutely. We offer Cash on Delivery so you can shop with confidence and pay when your order arrives at your doorstep.</p>",
            "page": ""
          }
        },
        "collapsible_row_JdV8GX": {
          "type": "collapsible_row",
          "settings": {
            "heading": "3. What if I receive a damaged or incorrect item?",
            "icon": "none",
            "row_content": "<p>If you receive a damaged, defective, or incorrect item, please contact our customer support team within <strong>24  hours of delivery</strong> with your order number and clear photos of the item received. We will review your request and arrange a replacement, exchange, or refund as applicable. Your satisfaction is our priority, and we will work to resolve the issue as quickly as possible.<br/><br/></p>",
            "page": ""
          }
        },
        "collapsible_row_bTwR38": {
          "type": "collapsible_row",
          "settings": {
            "heading": "4. How long does delivery take?",
            "icon": "none",
            "row_content": "<p>Delivery times may vary depending on your location and product availability. Most orders<br/>are delivered within a few business days after confirmation.</p>",
            "page": ""
          }
        },
        "collapsible_row_y7R4it": {
          "type": "collapsible_row",
          "settings": {
            "heading": "6. How do I launder ProSwag garments?",
            "icon": "none",
            "row_content": "<p>We suggest our shirts be machine washed in cold water and tumble dried on low to help protect the integrity of the material and the customization.</p><p>Please note that garments with DTF (Direct-to-Fabric) customization should not be dry cleaned. The chemicals and heat used in the dry cleaning process can cause the DTF print to peel or deteriorate, damaging the design and garment.</p>",
            "page": ""
          }
        }
      },
